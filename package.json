{
  "name": "janus-parse",
  "license": "MIT",
  "version": "0.0.0-semantically-released",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "packageManager": "pnpm@11.15.1",
  "keywords": [
    "html-parser",
    "text-extractor",
    "html-to-text",
    "html-sanitizer",
    "isomorphic",
    "typescript",
    "dom-parser",
    "clean-text",
    "strip-tags",
    "node-html-parser"
  ],
  "files": [
    "dist"
  ],
  "release": {
    "branches": [
      "main"
    ],
    "plugins": [
      "@semantic-release/commit-analyzer",
      "@semantic-release/release-notes-generator",
      "@semantic-release/npm",
      "@semantic-release/github"
    ]
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Casneil/janus-parse"
  },
  "homepage": "https://github.com/Casneil/janus-parse",
  "bugs": {
    "url": "https://github.com/Casneil/janus-parse/issues"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org"
  },
  "type": "module",
  "prepack": "pnpm build",
  "scripts": {
    "janus": "tsx ./lib",
    "test": "vitest",
    "code:lint": "pnpm eslint --flag unstable_native_nodejs_ts_config --cache .",
    "fmt": "prettier --write .",
    "type:check": "tsc --noEmit",
    "build": "tsc",
    "prepublishOnly": "pnpm build"
  },
  "dependencies": {
    "node-html-parser": "9.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@semantic-release/commit-analyzer": "^13.0.1",
    "@semantic-release/github": "^12.0.9",
    "@semantic-release/npm": "^13.1.5",
    "@semantic-release/release-notes-generator": "^14.1.1",
    "@types/node": "^26.1.1",
    "eslint": "^10.7.0",
    "eslint-import-resolver-typescript": "^4.4.5",
    "eslint-plugin-import-x": "^4.17.1",
    "eslint-plugin-unicorn": "^72.0.0",
    "happy-dom": "^20.11.0",
    "prettier": "^3.9.6",
    "semantic-release": "^25.0.8",
    "tsx": "4.23.1",
    "typescript": "6.0.3",
    "typescript-eslint": "^8.65.0",
    "vitest": "^4.1.10"
  },
  "prettier": {},
  "--Typescript V 7--": "cannot use TS v7 until typescript-eslint adds support"
}
